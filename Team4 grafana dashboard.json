      "targets": [
        {
          "datasource": {
            "type": "grafana-postgresql-datasource",
            "uid": "ffotfjp4mu60wf"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH global_max AS (\r\n    SELECT\r\n        MAX(ABS(value)) AS max_abs_value\r\n    FROM public.iot_events\r\n    WHERE sensor_id IN ('MACTTORQUE[1]', 'MACTTORQUE[2]', 'MACTTORQUE[3]')\r\n      AND server_timestamp >= now() - interval '2 hours'\r\n)\r\nSELECT\r\n    e.server_timestamp AS time,\r\n    e.sensor_id,\r\n    ABS(e.value) AS abs_value,\r\n    --g.max_abs_value,\r\n    0.9 * g.max_abs_value AS threshold_80_percent\r\nFROM public.iot_events e\r\nCROSS JOIN global_max g\r\nWHERE e.sensor_id IN ('MACTTORQUE[1]', 'MACTTORQUE[2]', 'MACTTORQUE[3]')\r\n  AND e.$__timeFilter(server_timestamp)\r\n  AND ABS(e.value) > 0.8 * g.max_abs_value\r\nORDER BY time;\r\n",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "All three motors with global limit",

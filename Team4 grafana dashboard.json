          "rawQuery": true,
          "rawSql": "SELECT\r\n    server_timestamp AS time,\r\n        EXTRACT(EPOCH FROM (\r\n        server_timestamp - LAG(server_timestamp) OVER (ORDER BY server_timestamp)\r\n    )) AS time_diff_seconds\r\nFROM public.iot_events\r\nWHERE sensor_id = 'ROBOTPOS.Z'\r\n  AND value < -99\r\n AND $__timeFilter(server_timestamp)\r\nORDER BY time;",
